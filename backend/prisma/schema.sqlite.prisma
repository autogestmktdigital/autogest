generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Usuários do sistema (admin/vendedores) ───

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("seller")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignedLeads Lead[]

  @@map("users")
}

// ─── Veículos ───

model Vehicle {
  id           Int      @id @default(autoincrement())
  brand        String
  model        String
  version      String?
  plate        String?
  chassis      String?
  renavam      String?
  year         Int
  modelYear    Int?     @map("model_year")
  price        Float
  mileageKm    Int      @map("mileage_km")
  fuel         String   @default("flex")
  color        String
  transmission String   @default("manual")
  description  String?
  features     String?
  images       String?
  reportFile   String?  @map("report_file")
  documentFile String?  @map("document_file")
  status       String   @default("available")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  financingSimulations FinancingSimulation[]
  expenses             VehicleExpense[]

  @@map("vehicles")
}

// ─── Gastos do Veículo ───

model VehicleExpense {
  id          Int      @id @default(autoincrement())
  vehicleId   Int      @map("vehicle_id")
  type        String
  description String
  amount      Float
  date        String
  createdAt   DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_expenses")
}

// ─── Venda do Veículo ───

model VehicleSale {
  id                 Int      @id @default(autoincrement())
  vehicleId          Int      @map("vehicle_id")
  salePrice          Float    @map("sale_price")
  saleDate           String   @map("sale_date")
  
  // Dados do Cliente
  clientName         String   @map("client_name")
  clientRg           String   @map("client_rg")
  clientCpfCnpj      String   @map("client_cpf_cnpj")
  clientPhone        String   @map("client_phone")
  clientEmail        String?  @map("client_email")
  clientAddress      String?  @map("client_address")
  clientDocuments    String?  @map("client_documents")
  
  // Condições da Compra
  paymentMethod      String   @map("payment_method")
  downPayment        Float?   @map("down_payment")
  financeCompany     String?  @map("finance_company")
  financeDate        String?  @map("finance_date")
  financedAmount     Float?   @map("financed_amount")
  installments       Int?
  installmentValue   Float?   @map("installment_value")
  
  // Veículo na Troca
  hasTradeIn         Boolean  @default(false) @map("has_trade_in")
  tradeInBrand       String?  @map("trade_in_brand")
  tradeInModel       String?  @map("trade_in_model")
  tradeInVersion     String?  @map("trade_in_version")
  tradeInPlate       String?  @map("trade_in_plate")
  tradeInYear        Int?     @map("trade_in_year")
  tradeInModelYear   Int?     @map("trade_in_model_year")
  tradeInFuel        String?  @map("trade_in_fuel")
  tradeInChassis     String?  @map("trade_in_chassis")
  tradeInRenavam     String?  @map("trade_in_renavam")
  tradeInPurchasePrice Float? @map("trade_in_purchase_price")
  tradeInDebts       Float?   @map("trade_in_debts")
  tradeInDebtsNotes  String?  @map("trade_in_debts_notes")
  tradeInNetValue    Float?   @map("trade_in_net_value")
  
  // Documentação
  documentationNotes String?  @map("documentation_notes")
  
  // Vendedor
  sellerId           Int?     @map("seller_id")
  sellerName         String?  @map("seller_name")
  
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("vehicle_sales")
}

// ─── Leads ───

model Lead {
  id                Int      @id @default(autoincrement())
  name              String?
  phone             String?
  email             String?
  channel           String
  channelUserId     String   @map("channel_user_id")
  interestNotes     String?  @map("interest_notes")
  status            String   @default("bot")
  assignedToId      Int?     @map("assigned_to")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  lastInteractionAt DateTime? @map("last_interaction_at")

  assignedTo            User?                 @relation(fields: [assignedToId], references: [id])
  conversations         Conversation[]
  financingSimulations  FinancingSimulation[]
  followUps             FollowUp[]

  @@unique([channel, channelUserId])
  @@map("leads")
}

// ─── Conversas ───

model Conversation {
  id               Int      @id @default(autoincrement())
  leadId           Int      @map("lead_id")
  channel          String
  typebotSessionId String?  @map("typebot_session_id")
  isHumanHandoff   Boolean  @default(false) @map("is_human_handoff")
  status           String   @default("active")
  assignedToId     Int?     @map("assigned_to")
  unreadCount      Int      @default(0) @map("unread_count")
  startedAt        DateTime @default(now()) @map("started_at")
  lastMessageAt    DateTime? @map("last_message_at")

  lead     Lead      @relation(fields: [leadId], references: [id])
  messages Message[]

  @@map("conversations")
}

// ─── Mensagens ───

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  role           String
  content        String
  mediaUrl       String?  @map("media_url")
  sentAt         DateTime @default(now()) @map("sent_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

// ─── Simulações de Financiamento ───

model FinancingSimulation {
  id             Int      @id @default(autoincrement())
  leadId         Int      @map("lead_id")
  vehicleId      Int      @map("vehicle_id")
  vehiclePrice   Float    @map("vehicle_price")
  downPayment    Float    @map("down_payment")
  installments   Int
  interestRate   Float    @map("interest_rate")
  monthlyPayment Float    @map("monthly_payment")
  totalPaid      Float    @map("total_paid")
  createdAt      DateTime @default(now()) @map("created_at")

  lead    Lead    @relation(fields: [leadId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("financing_simulations")
}

// ─── Follow-ups ───

model FollowUp {
  id             Int       @id @default(autoincrement())
  leadId         Int       @map("lead_id")
  type           String
  messageContent String?   @map("message_content")
  status         String    @default("scheduled")
  scheduledFor   DateTime  @map("scheduled_for")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("follow_ups")
}
