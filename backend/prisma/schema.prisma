generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Usuários do sistema (admin/vendedores) ───

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(seller)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignedLeads Lead[]

  @@map("users")
}

enum UserRole {
  admin
  seller
}

// ─── Veículos ───

model Vehicle {
  id           Int                 @id @default(autoincrement())
  brand        String              @db.VarChar(50)
  model        String              @db.VarChar(100)
  year         Int
  price        Float
  mileageKm    Int                 @map("mileage_km")
  fuel         FuelType
  color        String              @db.VarChar(30)
  transmission TransmissionType    @default(manual)
  description  String?             @db.Text
  features     Json?
  images       Json?
  status       VehicleStatus       @default(available)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  financingSimulations FinancingSimulation[]

  @@index([brand, model])
  @@index([price])
  @@index([status])
  @@map("vehicles")
}

enum FuelType {
  flex
  gasoline
  diesel
  electric
  hybrid
}

enum TransmissionType {
  manual
  automatic
}

enum VehicleStatus {
  available
  reserved
  sold
}

// ─── Leads ───

model Lead {
  id            Int        @id @default(autoincrement())
  name          String?    @db.VarChar(100)
  phone         String?    @db.VarChar(20)
  email         String?    @db.VarChar(150)
  channel       Channel
  channelUserId String     @map("channel_user_id") @db.VarChar(100)
  interestNotes String?    @map("interest_notes") @db.Text
  status        LeadStatus @default(new_lead)
  assignedToId  Int?       @map("assigned_to")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  assignedTo            User?                 @relation(fields: [assignedToId], references: [id])
  conversations         Conversation[]
  financingSimulations  FinancingSimulation[]
  followUps             FollowUp[]

  @@unique([channel, channelUserId])
  @@index([status])
  @@index([channel])
  @@map("leads")
}

enum Channel {
  whatsapp
  instagram
  facebook
}

enum LeadStatus {
  new_lead
  contacted
  negotiating
  converted
  lost
}

// ─── Conversas ───

model Conversation {
  id               Int                @id @default(autoincrement())
  leadId           Int                @map("lead_id")
  channel          Channel
  typebotSessionId String?            @map("typebot_session_id") @db.VarChar(255)
  isHumanHandoff   Boolean            @default(false) @map("is_human_handoff")
  status           ConversationStatus @default(active)
  startedAt        DateTime           @default(now()) @map("started_at")
  lastMessageAt    DateTime?          @map("last_message_at")

  lead     Lead      @relation(fields: [leadId], references: [id])
  messages Message[]

  @@index([leadId])
  @@index([status])
  @@map("conversations")
}

enum ConversationStatus {
  active
  paused
  closed
}

// ─── Mensagens ───

model Message {
  id             Int         @id @default(autoincrement())
  conversationId Int         @map("conversation_id")
  role           MessageRole
  content        String      @db.Text
  mediaUrl       String?     @map("media_url") @db.VarChar(500)
  sentAt         DateTime    @default(now()) @map("sent_at")

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

enum MessageRole {
  customer
  bot
  agent
}

// ─── Simulações de Financiamento ───

model FinancingSimulation {
  id             Int      @id @default(autoincrement())
  leadId         Int      @map("lead_id")
  vehicleId      Int      @map("vehicle_id")
  vehiclePrice   Float    @map("vehicle_price")
  downPayment    Float    @map("down_payment")
  installments   Int
  interestRate   Float    @map("interest_rate")
  monthlyPayment Float    @map("monthly_payment")
  totalPaid      Float    @map("total_paid")
  createdAt      DateTime @default(now()) @map("created_at")

  lead    Lead    @relation(fields: [leadId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([leadId])
  @@map("financing_simulations")
}

// ─── Follow-ups ───

model FollowUp {
  id             Int            @id @default(autoincrement())
  leadId         Int            @map("lead_id")
  type           FollowUpType
  messageContent String?        @map("message_content") @db.Text
  status         FollowUpStatus @default(scheduled)
  scheduledFor   DateTime       @map("scheduled_for")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([status, scheduledFor])
  @@map("follow_ups")
}

enum FollowUpType {
  welcome_24h
  check_interest
  new_vehicles
  price_drop
}

enum FollowUpStatus {
  scheduled
  sent
  failed
  cancelled
}
