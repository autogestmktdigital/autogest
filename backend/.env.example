# Exemplo de variáveis de ambiente para produção
# Copie este arquivo para .env e preencha com seus valores reais

# Banco de dados PostgreSQL (Railway fornece isso automaticamente)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Segurança - GERE UMA CHAVE FORTE! (minimo 32 caracteres)
JWT_SECRET="sua-chave-secreta-muito-forte-aqui-minimo-32-caracteres"
JWT_EXPIRES_IN="7d"

# Porta e ambiente
PORT=3001
NODE_ENV=production

# Configuracoes de upload (Cloudinary)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="sua-api-secret"

# Tamanho maximo de arquivo (MB)
MAX_FILE_SIZE_MB=10

# OpenAI (opcional - para bot inteligente)
OPENAI_API_KEY="sk-..."

# Meta/Facebook (opcional - para WhatsApp/Messenger)
META_APP_ID=""
META_APP_SECRET=""
META_VERIFY_TOKEN=""
META_PAGE_ACCESS_TOKEN=""
META_WHATSAPP_TOKEN=""
META_PHONE_NUMBER_ID=""

# Typebot (opcional - para fluxos de conversa)
TYPEBOT_API_URL=""
TYPEBOT_API_TOKEN=""
TYPEBOT_BOT_ID=""
